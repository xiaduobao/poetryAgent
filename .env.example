# LLM：通义千问（DashScope OpenAI 兼容模式）
OPENAI_API_KEY=your-dashscope-api-key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Embedding / Rerank
EMBEDDING_MODEL=./data/models/BAAI--bge-small-zh-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
HF_ENDPOINT=https://hf-mirror.com

# 数据存储（留空则使用 SQLite；生产推荐 PostgreSQL）
# DATABASE_URL=postgresql://poetry:poetry@postgres:5432/poetry_agent
CHROMA_PERSIST_DIR=./data/chroma_db
CORPUS_DIR=./data/corpus
SESSIONS_DB=./data/sessions.db

# 环境
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false

# JWT 认证（生产务必更换）
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_RAG=30/minute
RATE_LIMIT_DEFAULT=120/hour
# RATE_LIMIT_STORAGE_URI=redis://redis:6379

# Redis（Checkpoint / 限流共享）
# REDIS_URL=redis://redis:6379/0

# LangSmith 可观测性
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=poetry-agent

# Sentry 错误追踪
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics 保护（留空则 /metrics 无需认证）
# METRICS_BASIC_AUTH_USER=metrics
# METRICS_BASIC_AUTH_PASSWORD=change-me

# 告警 Webhook（钉钉/飞书）
# ALERT_WEBHOOK_URL=

# 阿里云内容安全（可选）
CONTENT_MODERATION_ENABLED=false
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_REGION=cn-shanghai

# 服务
API_HOST=0.0.0.0
API_PORT=8000
