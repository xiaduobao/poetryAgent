# 本地开发环境配置模板（dev）
# 复制为 .env 并填写实际值：
#   cp .env.example .env
#
# ECS 生产环境请使用 .env.prod.example → .env.prod，勿与本文件混用

# LLM：通义千问（DashScope OpenAI 兼容模式）
OPENAI_API_KEY=your-dashscope-api-key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
# qwen3.7-plus 等混合思考模型：false=关闭思考（推荐，Agent 多轮调用更快）；true=深度推理
LLM_ENABLE_THINKING=false
VISION_MODEL=qwen-vl-max

# Embedding / Rerank
EMBEDDING_MODEL=./data/models/BAAI--bge-small-zh-v1.5
RERANK_MODEL=./data/models/BAAI--bge-reranker-base
HF_ENDPOINT=https://hf-mirror.com
# Rerank 性能（CPU 建议保持默认；仍慢可 RERANK_ENABLED=false 或减小候选数）
# RERANK_MAX_CANDIDATES=6
# RERANK_MAX_LENGTH=512
# RERANK_BATCH_SIZE=16
# RERANK_ENABLED=true

# 数据存储（推荐本地也走 Docker 基础设施，与生产一致）
# 先启动：docker compose -f docker-compose.infra.yml up -d
DATABASE_URL=postgresql://poetry:poetry@localhost:5432/poetry_agent
CHROMA_PERSIST_DIR=./data/chroma_db
CORPUS_DIR=./data/corpus
# 仅在不配置 DATABASE_URL 时使用 SQLite
# SESSIONS_DB=./data/sessions.db

# 环境  
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false

# JWT 认证（生产务必更换）
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_RAG=30/minute
RATE_LIMIT_DEFAULT=120/hour
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/1

# Redis（Checkpoint / 限流共享）
REDIS_URL=redis://localhost:6379/0

# 复合意图（单条消息多问题拆解）；默认关闭，验证后可设为 true
COMPOUND_INTENT_ENABLED=false

# 有限 ReAct（工具多轮 / 低置信度兜底 / RAG-as-tool）
REACT_ENABLED=true
REACT_MAX_STEPS=3
REACT_LOW_CONFIDENCE_THRESHOLD=0.65
REACT_LOW_CONFIDENCE_FALLBACK=true
# 工具 ReAct 多轮：仅低置信度或指代性提问（「这首诗」缺诗题）时启用；高置信度 rule 走 legacy 单轮
REACT_TOOL_LOOP_ENABLED=true
REACT_RAG_AS_TOOL_ENABLED=true
REACT_RAG_MAX_SEARCHES=2

# LangSmith 可观测性
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=poetry-agent-dev

# Sentry 错误追踪
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics 保护（留空则 /metrics 无需认证）
# METRICS_BASIC_AUTH_USER=metrics
# METRICS_BASIC_AUTH_PASSWORD=change-me

# 告警 Webhook（钉钉/飞书）
# ALERT_WEBHOOK_URL=

# 阿里云内容安全（可选）
CONTENT_MODERATION_ENABLED=false
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_REGION=cn-shanghai

# 服务
API_HOST=0.0.0.0
API_PORT=8000
