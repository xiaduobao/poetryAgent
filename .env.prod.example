# 生产环境（ECS）配置模板
# 复制为 .env.prod 并填写实际值：
#   cp .env.prod.example .env.prod
#
# 发布时 deploy.sh 仅上传 .env.prod，不会覆盖本地 .env

# LLM：通义千问（DashScope OpenAI 兼容模式）
OPENAI_API_KEY=your-dashscope-api-key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
VISION_MODEL=qwen-vl-max

# Embedding / Rerank（填 data/models/ 下实际目录名，常见两种命名）
#   download_models.py → BAAI--bge-small-zh-v1.5
#   huggingface-cli 手动下载 → bge-small-zh-v1.5
EMBEDDING_MODEL=./data/models/bge-small-zh-v1.5
RERANK_MODEL=./data/models/bge-reranker-base
HF_ENDPOINT=https://hf-mirror.com

# 数据存储（DATABASE_URL / REDIS_URL 由 docker-compose 注入，此处无需配置）
CHROMA_PERSIST_DIR=/app/data/chroma_db
CORPUS_DIR=/app/data/corpus
SESSIONS_DB=/app/data/sessions.db

# 环境
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# JWT 认证（生产务必使用独立随机密钥，勿与 dev 相同）
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# CORS（生产域名，逗号分隔）
CORS_ORIGINS=http://your-ecs-ip,https://your-domain.com

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_RAG=30/minute
RATE_LIMIT_DEFAULT=120/hour

# LangSmith 可观测性（建议与 dev 使用不同 project）
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=poetry-agent-prod

# Sentry 错误追踪
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics 保护（留空则 /metrics 无需认证）
# METRICS_BASIC_AUTH_USER=metrics
# METRICS_BASIC_AUTH_PASSWORD=change-me

# 告警 Webhook（钉钉/飞书）
# ALERT_WEBHOOK_URL=

# 阿里云内容安全（可选）
CONTENT_MODERATION_ENABLED=false
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_REGION=cn-shanghai

# 服务
API_HOST=0.0.0.0
API_PORT=8000
