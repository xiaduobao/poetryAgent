# 复制为 deploy.env 并填写实际值：
#   cp scripts/deploy/deploy.env.example scripts/deploy/deploy.env

# ECS 公网 IP
ECS_HOST=47.x.x.x

# SSH 登录用户（阿里云 Linux 默认 root）
ECS_USER=root

# SSH 端口
ECS_PORT=22

# SSH 私钥路径（阿里云 ECS 创建时下载的 .pem）
SSH_KEY=~/.ssh/aliyun.pem

# 远程项目目录
REMOTE_DIR=/opt/poetry-agent

# ---- 阿里云 ACR（示例：personal 实例）----
# POETRY_AGENT_IMAGE=crpi-xxxxx.ap-southeast-1.personal.cr.aliyuncs.com/bobpoc/poetryagent:latest
# ACR_REGISTRY=crpi-xxxxx.ap-southeast-1.personal.cr.aliyuncs.com
# ACR_USERNAME=your-aliyun-account
# ACR_PASSWORD=your-acr-token
#
# 构建镜像（二选一）：
#   ./scripts/deploy/build-on-ecs.sh      # 在 ECS 上 build + push（推荐，不在本地打）
#   ./scripts/deploy/build-push-acr.sh    # 在本地 Mac build + push
