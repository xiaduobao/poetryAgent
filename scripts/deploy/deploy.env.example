# 复制为 deploy.env 并填写实际值：
#   cp scripts/deploy/deploy.env.example scripts/deploy/deploy.env

# ECS 公网 IP
ECS_HOST=47.x.x.x

# SSH 登录用户（阿里云 Linux 默认 root）
ECS_USER=root

# SSH 端口
ECS_PORT=22

# SSH 私钥路径（阿里云 ECS 创建时下载的 .pem）
SSH_KEY=~/.ssh/aliyun.pem

# 远程项目目录
REMOTE_DIR=/opt/poetry-agent

# ---- ACR 镜像（在 ACR 控制台手动 build，ECS 只 pull）----
# 推荐拉取地址（新加坡 personal 实例，带 :latest 标签）：
POETRY_AGENT_IMAGE=crpi-60eut63p9vp6h7li.ap-southeast-1.personal.cr.aliyuncs.com/bobpoc/poetryagent:latest

# ECS 首次 pull 前需 docker login（ACR 控制台 -> 访问凭证 -> 固定密码）
ACR_REGISTRY=crpi-60eut63p9vp6h7li.ap-southeast-1.personal.cr.aliyuncs.com
# ACR_USERNAME=你的阿里云账号
# ACR_PASSWORD=ACR固定密码
#
# Dockerfile 基础镜像使用 registry.ap-southeast-1.aliyuncs.com/library/（同区域官方代理）
# 若构建仍失败，可在 ACR 制品中心订阅 node/python 同步到 bobpoc 命名空间后改用：
# FROM crpi-60eut63p9vp6h7li.ap-southeast-1.personal.cr.aliyuncs.com/bobpoc/node:20-slim
