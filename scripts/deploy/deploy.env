# 复制为 deploy.env 并填写实际值：
#   cp scripts/deploy/deploy.env.example scripts/deploy/deploy.env

# ECS 公网 IP
ECS_HOST=8.134.168.40

# SSH 登录用户（阿里云 Linux 默认 root）
ECS_USER=root

# SSH 端口
ECS_PORT=22

# SSH 私钥路径（阿里云 ECS 创建时下载的 .pem）
SSH_KEY=~/.ssh/mac_bob.pem

# 远程项目目录
REMOTE_DIR=/opt/poetry-agent

# ---- 阿里云 ACR（新加坡 personal 实例）----
POETRY_AGENT_IMAGE=crpi-60eut63p9vp6h7li.ap-southeast-1.personal.cr.aliyuncs.com/bobpoc/poetryagent:latest
ACR_REGISTRY=crpi-60eut63p9vp6h7li.ap-southeast-1.personal.cr.aliyuncs.com
# ACR_USERNAME=你的阿里云账号
# ACR_PASSWORD=ACR控制台-访问凭证-固定密码
