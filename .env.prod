# ECS 生产环境（deploy.sh 仅上传此文件，不影响本地 .env）

# LLM：通义千问（DashScope OpenAI 兼容模式）
OPENAI_API_KEY=sk-fc125f720e93470aa92fcd8b435775bf
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
VISION_MODEL=qwen-vl-max

# Embedding / Rerank（容器内路径）
EMBEDDING_MODEL=./data/models/BAAI--bge-small-zh-v1.5
RERANK_MODEL=./data/models/BAAI--bge-reranker-base
HF_ENDPOINT=https://hf-mirror.com

# 数据存储（DATABASE_URL / REDIS_URL 由 docker-compose 注入）
CHROMA_PERSIST_DIR=/app/data/chroma_db
CORPUS_DIR=/app/data/corpus
SESSIONS_DB=/app/data/sessions.db

# 环境
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# JWT（生产独立密钥，与 dev 不同）
JWT_SECRET_KEY=8f3a2c91e7b54d6a0f1e9c8b7a6d5e4f3c2b1a0987654321fedcba
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://8.134.168.40

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_RAG=30/minute
RATE_LIMIT_DEFAULT=120/hour

# LangSmith（与 dev 分 project）
LANGSMITH_API_KEY=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
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=poetry-agent-prod

# 内容安全
CONTENT_MODERATION_ENABLED=false

# 服务
API_HOST=0.0.0.0
API_PORT=8000
